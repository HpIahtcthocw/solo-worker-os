# Agent provider: qwen | claude | openai
# Alternatively, set COMPETITION_MODE=qwen | casper to auto-select provider.
AGENT_PROVIDER=qwen

# ── Competition mode (optional) ──────────────────────────────
# COMPETITION_MODE=qwen     → uses Qwen Cloud (Global AI Hackathon Series)
# COMPETITION_MODE=casper   → uses Qwen + Casper blockchain tools (Casper Buildathon)
# COMPETITION_MODE=(unset)  → standard Solo Worker OS behavior

# ── LLM providers ────────────────────────────────────────────
# Qwen Cloud / DashScope (default provider)
DASHSCOPE_API_KEY=sk-xxxxxxxx
QWEN_MODEL=qwen-plus

# Anthropic Claude (used when AGENT_PROVIDER=claude)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# OpenAI (used when AGENT_PROVIDER=openai)
# OPENAI_API_KEY=sk-xxxxxxxx

# ── Casper Network (used when COMPETITION_MODE=casper) ───────
# NEXT_PUBLIC_CASPER_RPC_URL=https://api.testnet.casper.network

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AGENT_PROVIDER=qwen
