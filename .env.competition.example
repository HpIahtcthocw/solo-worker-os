# ──────────────────────────────────────────────────────────────
# Competition Mode — Environment Variables
# Copy the relevant section to your .env.local file.
# ──────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────
# Enable competition mode. Options: qwen | casper | (unset = default)
COMPETITION_MODE=

# Override the LLM provider directly (alternative to COMPETITION_MODE).
# Options: claude (default) | openai | qwen
AGENT_PROVIDER=


# ── Qwen Cloud (Global AI Hackathon Series) ──────────────────
# Get your API key from https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=

# Qwen model to use. Options: qwen-turbo | qwen-plus | qwen-max
QWEN_MODEL=qwen-plus


# ── Casper Network (Agentic Buildathon 2026) ─────────────────
# Public Casper Testnet RPC. Override if you run your own node.
NEXT_PUBLIC_CASPER_RPC_URL=https://api.testnet.casper.network

# Optional: Casper API key if using a rate-limited endpoint
# CASPER_API_KEY=
